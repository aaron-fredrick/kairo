# Copy to .env and adjust for local development.
#
# GitHub Actions: add repository secret CODECOV_TOKEN (Settings → Secrets → Actions).
# Local bundle analysis: export CODECOV_TOKEN before `npm run build` in frontend/.

CODECOV_TOKEN=your_codecov_token_here

# Database (CI uses sqlite + local event bus via tests/conftest.py)
DB_BACKEND=sqlite
EVENT_BUS=local

# Object storage — blobs, temp uploads, thumbnails, and pfps all use this backend.
# UPLOAD_BACKEND: local | s3 | minio | ftp
UPLOAD_BACKEND=minio

# AWS S3 (UPLOAD_BACKEND=s3)
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=

# MinIO (UPLOAD_BACKEND=minio) — start with: docker compose up -d minio minio-init
MINIO_ENDPOINT=http://127.0.0.1:7000
MINIO_ACCESS_KEY=username
MINIO_SECRET_KEY=password
MINIO_BUCKET=kairo
MINIO_REGION=us-east-1
DATA_DIR=data

# app-register (distributed app-backend nodes) — same key on app-register + all backends
REGISTER_ENABLED=false
REGISTER_URL=http://127.0.0.1:8100
# Docker: REGISTER_URL=http://app-register:8100
REGISTER_SYSTEM_KEY=change_me_register_system_key
REGISTER_INSTANCE_HOST=127.0.0.1
REGISTER_INSTANCE_PORT=8000
REGISTER_INSTANCE_SCHEME=http
REGISTER_INSTANCE_NAME=

# Register service only (when running app_register/main.py)
REGISTER_HOST=0.0.0.0
REGISTER_PORT=8100
PROXY_TYPE=caddy
PROXY_CONFIG_PATH=/etc/caddy/Caddyfile
PROXY_RELOAD_COMMAND=
PUBLIC_LISTEN=:80
