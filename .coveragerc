[run]
source = app_backend, app_register
branch = True
omit =
    */tests/*
    */migrations/*
    app_backend/main.py
    app_backend/services/chat_service.py
    app_backend/services/presence_service.py
    app_backend/utils/__init__.py
    app_backend/storage/backends.py
    app_backend/db/redis.py

[report]
show_missing = True
skip_empty = True
precision = 2

[xml]
output = coverage.xml
